# ============================================
# FINANZAS 4.0 — Variables de entorno
# ============================================

# --- Base de datos principal (PostgreSQL) ---
# Formato: postgres://usuario:password@host:puerto/basedatos
# Schema: finanzas2 (se crea automáticamente al iniciar)
DATABASE_URL=postgres://admin:admin@72.60.241.216:9595/datos?sslmode=disable

# --- CORS ---
# Orígenes permitidos separados por coma
# En EasyPanel: https://tu-app.easypanel.host
CORS_ORIGINS=*

# --- Odoo POS Sync (opcional) ---
# Solo si usas sincronización con módulo Odoo
# ODOO_MODULE_BASE_URL=http://odoo-backend:8002
# ODOO_SYNC_TOKEN=tu-token-sync

# --- Frontend (build arg en Docker, NO variable de runtime) ---
# Dejar vacío para URLs relativas (nginx proxea /api/ al backend)
REACT_APP_BACKEND_URL=
